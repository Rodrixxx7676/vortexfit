@model VortexFit.Models.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión — Style Gym";
    Layout = "_Layout";
}

<div class="auth-page">
    <div class="auth-card">

        <!-- Logo -->
        <a href="/" class="auth-logo">
            <img src="/images/stylegym_t.png?v=4" alt="Style Gym" style="height:60px; display:block; margin:0 auto;">
        </a>
        <p class="auth-subtitle">Bienvenido de vuelta <i class="fa-solid fa-hand-wave"></i></p>

        <!-- Mensaje de éxito (ej: después de registrarse) -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="auth-alert auth-alert-success">
                <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
            </div>
        }

        <!-- Bloqueo por intentos -->
        @if (ViewBag.Permanent == true)
        {
            <div class="auth-alert auth-alert-error">
                <i class="fa-solid fa-ban"></i> <strong>Cuenta bloqueada.</strong>
                Demasiados intentos fallidos. Contacta al soporte del gimnasio.
            </div>
        }
        else if (ViewBag.LockSeconds != null)
        {
            <div class="auth-alert auth-alert-error" id="lockAlert">
                <i class="fa-solid fa-lock"></i>
                Demasiados intentos. Podrás intentarlo de nuevo en
                <strong id="lockCountdown">@ViewBag.LockSeconds</strong> segundo@(ViewBag.LockSeconds != 1 ? "s" : "").
            </div>
        }

        <!-- Errores globales -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0 && ViewBag.LockSeconds == null && ViewBag.Permanent != true)
        {
            <div class="auth-alert auth-alert-error">
                <i class="fa-solid fa-triangle-exclamation"></i> @Html.ValidationSummary(true, "", new { @class = "mb-0" })
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post" novalidate id="loginForm">
            <input type="hidden" asp-for="@ViewData["ReturnUrl"]" name="returnUrl" />
            <input type="hidden" asp-for="RecaptchaToken" id="recaptchaToken" />
            @Html.AntiForgeryToken()

            <!-- Correo -->
            <div class="form-group">
                <label asp-for="Email">Correo electrónico</label>
                <input asp-for="Email"
                       type="email"
                       class="form-input"
                       placeholder="tucorreo@ejemplo.com"
                       autocomplete="email" />
                <span asp-validation-for="Email" class="form-error"></span>
            </div>

            <!-- Contraseña -->
            <div class="form-group">
                <div class="form-label-row">
                    <label asp-for="Password">Contraseña</label>
                    <a href="#" class="form-link">¿Olvidaste tu contraseña?</a>
                </div>
                <div class="input-password-wrap">
                    <input asp-for="Password"
                           type="password"
                           class="form-input"
                           placeholder="••••••••"
                           id="passwordInput"
                           autocomplete="current-password" />
                    <button type="button" class="toggle-password" onclick="togglePassword('passwordInput', this)" aria-label="Ver contraseña">
                        <i class="fa-regular fa-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="form-error"></span>
            </div>

            <!-- Recordarme -->
            <div class="form-check">
                <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                <label for="rememberMe">Recordarme en este dispositivo</label>
            </div>

            <!-- Botón -->
            <button type="submit" class="btn-primary btn-full">
                Iniciar sesión
            </button>
        </form>

        <p class="auth-footer-text">
            ¿No tienes cuenta?
            <a asp-action="Register" asp-controller="Account" class="form-link">Regístrate gratis</a>
        </p>

        <p class="recaptcha-notice">
            Protegido por reCAPTCHA —
            <a href="https://policies.google.com/privacy" target="_blank" rel="noopener">Privacidad</a> y
            <a href="https://policies.google.com/terms"   target="_blank" rel="noopener">Términos</a>
        </p>

        <button type="button" class="soporte-link btn-soporte">
            <i class="fa-solid fa-headset"></i> ¿Necesitas ayuda? Soporte técnico
        </button>

    </div>
</div>

@await Html.PartialAsync("_SoporteModal")

@section Scripts {
    <script src="https://www.google.com/recaptcha/api.js?render=@ViewBag.RecaptchaSiteKey"></script>
    <script>
        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                btn.innerHTML = '<i class="fa-regular fa-eye-slash"></i>';
            } else {
                input.type = 'password';
                btn.innerHTML = '<i class="fa-regular fa-eye"></i>';
            }
        }

        // Contador regresivo de bloqueo
        const lockEl = document.getElementById('lockCountdown');
        if (lockEl) {
            const submitBtn = document.querySelector('#loginForm button[type=submit]');
            if (submitBtn) submitBtn.disabled = true;

            let secs = parseInt(lockEl.textContent, 10);
            const tick = setInterval(() => {
                secs--;
                if (secs <= 0) {
                    clearInterval(tick);
                    document.getElementById('lockAlert').innerHTML =
                        '<i class="fa-solid fa-unlock"></i> Ya puedes intentarlo de nuevo.';
                    document.getElementById('lockAlert').className = 'auth-alert auth-alert-success';
                    if (submitBtn) submitBtn.disabled = false;
                } else {
                    lockEl.textContent = secs;
                }
            }, 1000);
        }

        // reCAPTCHA v3 — intercepta el submit con feedback visual + timeout fallback
        const loginForm = document.getElementById('loginForm');
        loginForm.addEventListener('submit', function (e) {
            e.preventDefault();
            const btn = loginForm.querySelector('button[type=submit]');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Verificando...';
            }

            function doSubmit(token) {
                document.getElementById('recaptchaToken').value = token || '';
                loginForm.submit();
            }

            // Timeout de 4 segundos: si reCAPTCHA no responde, enviar igual
            const fallback = setTimeout(() => doSubmit(''), 4000);

            if (typeof grecaptcha !== 'undefined') {
                grecaptcha.ready(function () {
                    grecaptcha.execute('@ViewBag.RecaptchaSiteKey', { action: 'login' })
                        .then(function (token) { clearTimeout(fallback); doSubmit(token); })
                        .catch(function ()      { clearTimeout(fallback); doSubmit(''); });
                });
            } else {
                clearTimeout(fallback);
                doSubmit('');
            }
        });
    </script>
}
