<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#3DD9D9" />

    <!-- SEO -->
    <meta name="description"  content="Style Gym — Gimnasio moderno con clases grupales, entrenadores certificados y seguimiento de progreso. Únete hoy." />
    <meta name="keywords"     content="gimnasio, fitness, clases, spinning, yoga, crossfit, membresía" />
    <meta name="author"       content="Style Gym" />
    <meta name="robots"       content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title"       content="@ViewData["Title"]" />
    <meta property="og:description" content="Entrena con los mejores instructores. Muévete sin límites." />
    <meta property="og:type"        content="website" />
    <meta property="og:locale"      content="es_PE" />

    <!-- ── PWA ── -->
    <link rel="manifest" href="/manifest.json" />

    <!-- iOS PWA support -->
    <meta name="apple-mobile-web-app-capable"          content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title"            content="Style Gym" />
    <link rel="apple-touch-icon" href="/images/icons/apple-touch-icon.png" />

    <!-- Windows / Edge tiles -->
    <meta name="msapplication-TileColor"  content="#3DD9D9" />
    <meta name="msapplication-TileImage"  content="/images/icons/icon-192.png" />

    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/vortex.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="96x96"  href="/images/icons/icon-96.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/icons/icon-192.png" />
    <link rel="shortcut icon" type="image/png"        href="/images/favicon.png" />

    <!-- Font Awesome -->
    <script src="https://kit.fontawesome.com/dd3d90ac36.js" crossorigin="anonymous"></script>

    <!-- Anti-flash: aplica el tema ANTES de pintar la página -->
    <script>(function(){var t=localStorage.getItem('sg-theme')||'dark';document.documentElement.setAttribute('data-theme',t);})();</script>
</head>
<body>

    <!-- Toast data desde TempData -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="toast-data" data-message="@TempData["SuccessMessage"]" data-type="success" style="display:none;"></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="toast-data" data-message="@TempData["ErrorMessage"]" data-type="error" style="display:none;"></div>
    }

    <!-- ── Banner PWA "Instalar app" ── -->
    <div id="pwa-banner" style="display:none;">
        <div class="pwa-banner-inner">
            <img src="/images/icons/icon-96.png" alt="Style Gym" />
            <div class="pwa-banner-text">
                <strong>Style Gym</strong>
                <span>Instala la app en tu dispositivo</span>
            </div>
            <button id="pwa-install-btn" class="btn-primary" style="white-space:nowrap; padding:0.5rem 1rem; font-size:0.85rem;">
                Instalar
            </button>
            <button id="pwa-dismiss-btn" aria-label="Cerrar">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
    </div>

    <!-- ── Navbar ── -->
    <nav class="navbar-vortex">
        <a href="/" class="navbar-logo">
            <img src="/images/stylegym_t.png?v=4" alt="Style Gym" style="height:36px; vertical-align:middle;">
        </a>

        <!-- Links escritorio -->
        <ul class="navbar-links">
            <li><a href="/#servicios">Servicios</a></li>
            <li><a href="/#clases">Clases</a></li>
            <li><a href="/#sedes">Sedes</a></li>
            <li><a href="/#planes">Planes</a></li>
            <li><a asp-controller="Noticias" asp-action="Index">Noticias</a></li>
        </ul>

        <!-- Toggle tema -->
        <button class="btn-theme-toggle" aria-label="Cambiar tema" title="Cambiar tema">
            <i class="fa-solid fa-sun theme-icon"></i>
        </button>

        <!-- Botones escritorio -->
        <div class="navbar-cta">
            @if (Context.Session.GetString("SocioRol") == "Admin")
            {
                <a asp-controller="Admin" asp-action="Index" class="btn-primary">
                    <i class="fa-solid fa-shield-halved"></i> Admin
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-outline" style="cursor:pointer;">Salir</button>
                </form>
            }
            else if (Context.Session.GetInt32("SocioId") != null)
            {
                <a asp-controller="Dashboard" asp-action="Index" class="btn-outline">Mi panel</a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-primary" style="border:none; cursor:pointer;">Salir</button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login"    class="btn-outline">Iniciar sesión</a>
                <a asp-controller="Account" asp-action="Register" class="btn-primary">Registrarse</a>
            }
        </div>

        <!-- Botón hamburguesa -->
        <button class="navbar-hamburger" id="hamburgerBtn" aria-label="Abrir menú">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <!-- Menú móvil -->
    <div class="navbar-mobile-menu" id="mobileMenu">
        <div class="mobile-links-group">
            <a href="/#servicios"   class="mobile-link">Servicios</a>
            <a href="/#clases"      class="mobile-link">Clases</a>
            <a href="/#sedes"       class="mobile-link">Sedes</a>
            <a href="/#planes"      class="mobile-link">Planes</a>
            <a href="/#testimonios" class="mobile-link">Testimonios</a>
            <a asp-controller="Noticias" asp-action="Index" class="mobile-link">Noticias</a>
        </div>
        <div class="navbar-mobile-cta">
            <a asp-controller="Account" asp-action="Login"    class="btn-outline">Iniciar sesión</a>
            <a asp-controller="Account" asp-action="Register" class="btn-primary">Registrarse gratis</a>
        </div>
    </div>

    <!-- ── Contenido ── -->
    <main>@RenderBody()</main>

    <!-- ── Footer ── -->
    <footer class="footer">
        <div class="footer-logo">
            <img src="/images/stylegym_t.png?v=4" alt="Style Gym" style="height:24px; vertical-align:middle; margin-right:6px;">
            Style Gym
        </div>
        <p>© 2026 Style Gym. Todos los derechos reservados.</p>
        <ul class="footer-links">
            <li><a href="/#servicios">Servicios</a></li>
            <li><a href="/#planes">Planes</a></li>
            <li><a href="#">Privacidad</a></li>
            <li><a href="#">Contacto</a></li>
        </ul>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/vortex.js" asp-append-version="true"></script>
    <script>
        // ── Hamburger ──────────────────────────────
        const btn  = document.getElementById('hamburgerBtn');
        const menu = document.getElementById('mobileMenu');
        btn.addEventListener('click', () => {
            btn.classList.toggle('open');
            menu.classList.toggle('open');
        });
        document.querySelectorAll('.mobile-link').forEach(l => l.addEventListener('click', () => {
            btn.classList.remove('open');
            menu.classList.remove('open');
        }));

        // ── Service Worker ─────────────────────────
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/js/sw.js')
                    .catch(err => console.warn('SW register failed:', err));
            });
        }

        // ── PWA Install Banner ─────────────────────
        let deferredPrompt = null;
        const pwaBanner     = document.getElementById('pwa-banner');
        const installBtn    = document.getElementById('pwa-install-btn');
        const dismissBtn    = document.getElementById('pwa-dismiss-btn');

        window.addEventListener('beforeinstallprompt', e => {
            e.preventDefault();
            deferredPrompt = e;
            // No mostrar si el usuario ya lo descartó antes
            if (sessionStorage.getItem('pwa-dismissed') !== '1') {
                setTimeout(() => pwaBanner.style.display = 'block', 3000);
            }
        });

        installBtn?.addEventListener('click', async () => {
            if (!deferredPrompt) return;
            deferredPrompt.prompt();
            const { outcome } = await deferredPrompt.userChoice;
            deferredPrompt = null;
            pwaBanner.style.display = 'none';
        });

        dismissBtn?.addEventListener('click', () => {
            pwaBanner.style.display = 'none';
            sessionStorage.setItem('pwa-dismissed', '1');
        });

        // Ocultar banner si la app ya está instalada
        window.addEventListener('appinstalled', () => {
            pwaBanner.style.display = 'none';
            deferredPrompt = null;
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
