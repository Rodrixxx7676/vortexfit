<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="apple-mobile-web-app-capable"          content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title"            content="Style Gym" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/images/icons/apple-touch-icon.png" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/vortex.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="64x64" href="/images/favicon.png" />
    <link rel="shortcut icon" type="image/png" href="/images/favicon.png" />

    <!-- Font Awesome -->
    <script src="https://kit.fontawesome.com/dd3d90ac36.js" crossorigin="anonymous"></script>
</head>
<body class="dash-body">

    <!-- ══ SIDEBAR ══ -->
    <aside class="sidebar" id="sidebar">
        <a href="/" class="sidebar-logo">
            <img src="/images/stylegym_t.png?v=4" alt="Style Gym" style="height:30px; vertical-align:middle; margin-right:8px;">
            Style Gym
        </a>

        <nav class="sidebar-nav">
            <span class="sidebar-section-label">Principal</span>
            <a asp-controller="Dashboard" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                <i class="fa-solid fa-house"></i> Mi panel
            </a>
            <a asp-controller="Dashboard" asp-action="Clases"
               class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Clases" ? "active" : "")">
                <i class="fa-solid fa-calendar-days"></i> Mis clases
            </a>
            <a asp-controller="Dashboard" asp-action="Progreso"
               class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Progreso" ? "active" : "")">
                <i class="fa-solid fa-chart-line"></i> Mi progreso
            </a>

            <a asp-controller="Dashboard" asp-action="QR"
               class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "QR" ? "active" : "")">
                <i class="fa-solid fa-qrcode"></i> Mi QR
            </a>

            <span class="sidebar-section-label">Cuenta</span>
            <a asp-controller="Dashboard" asp-action="Perfil"
               class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Perfil" ? "active" : "")">
                <i class="fa-solid fa-user"></i> Mi perfil
            </a>
            <a asp-controller="Dashboard" asp-action="Membresia"
               class="sidebar-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Membresia" ? "active" : "")">
                <i class="fa-solid fa-credit-card"></i> Membresía
            </a>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-user">
                <div class="sidebar-avatar">
                    @(Context.Session.GetString("SocioNombre")?[0] ?? 'S')
                </div>
                <div class="sidebar-user-info">
                    <p class="sidebar-user-name">@Context.Session.GetString("SocioNombre")</p>
                    <p class="sidebar-user-plan">Plan @Context.Session.GetString("SocioPlan")</p>
                </div>
            </div>

            <form asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="sidebar-logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Cerrar sesión
                </button>
            </form>
        </div>
    </aside>

    <!-- ══ OVERLAY (mobile) ══ -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- Formulario oculto para cierre de sesión por inactividad -->
    <form id="inactivityLogoutForm" asp-controller="Account" asp-action="Logout" method="post" style="display:none;">
        @Html.AntiForgeryToken()
    </form>

    <!-- Toast data desde TempData -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div id="toast-data" data-message="@TempData["SuccessMessage"]" data-type="success" style="display:none;"></div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div id="toast-data" data-message="@TempData["ErrorMessage"]" data-type="error" style="display:none;"></div>
    }

    <!-- ══ CONTENIDO PRINCIPAL ══ -->
    <div class="dash-content">

        <!-- Topbar móvil -->
        <div class="dash-topbar">
            <button class="dash-menu-btn" id="menuBtn" aria-label="Abrir menú">
                <span></span><span></span><span></span>
            </button>
            <a href="/" class="dash-topbar-logo">
                <img src="/images/stylegym_t.png?v=4" alt="Style Gym" style="height:26px; vertical-align:middle; margin-right:6px;">
                Style Gym
            </a>
            <div class="dash-topbar-user">
                @Context.Session.GetString("SocioNombre")?.Split(' ')[0]
            </div>
        </div>

        <!-- Cuerpo de la página -->
        <main class="dash-main">
            @RenderBody()
        </main>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/vortex.js" asp-append-version="true"></script>
    <script>
        const menuBtn = document.getElementById('menuBtn');
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebarOverlay');
        menuBtn.addEventListener('click', () => {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
        overlay.addEventListener('click', () => {
            sidebar.classList.remove('open');
            overlay.classList.remove('open');
        });
    </script>

    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/js/sw.js')
                .then(async reg => {
                    if (!('PushManager' in window)) return;
                    const perm = await Notification.requestPermission();
                    if (perm !== 'granted') return;
                    const existing = await reg.pushManager.getSubscription();
                    if (existing) return;
                    const keyResp = await fetch('/api/push/publickey');
                    if (!keyResp.ok) return;
                    const { publicKey } = await keyResp.json();
                    const sub = await reg.pushManager.subscribe({
                        userVisibleOnly: true,
                        applicationServerKey: publicKey
                    });
                    const k = sub.getKey('p256dh');
                    const a = sub.getKey('auth');
                    await fetch('/api/push/subscribe', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            endpoint: sub.endpoint,
                            p256dh: k ? btoa(String.fromCharCode(...new Uint8Array(k))) : '',
                            auth:   a ? btoa(String.fromCharCode(...new Uint8Array(a))) : ''
                        })
                    });
                })
                .catch(err => console.warn('SW register failed:', err));
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
