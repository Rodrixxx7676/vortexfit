                        <th>Cupo</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>06:00 am</td>
                        <td><span class="badge-class badge-spinning">Spinning</span></td>
                        <td><span class="badge-class badge-spinning">Spinning</span></td>
                        <td><span class="badge-class badge-spinning">Spinning</span></td>
                        <td>—</td>
                        <td>Carlos Herrera</td>
                        <td>20 lugares</td>
                    </tr>
                    <tr>
                        <td>08:00 am</td>
                        <td><span class="badge-class badge-yoga">Yoga</span></td>
                        <td>—</td>
