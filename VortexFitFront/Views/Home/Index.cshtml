@{
    ViewData["Title"] = "Style Gym — Muévete sin límites";
    Layout = "_Layout";
}

<!-- ══════════════════════════════════════════
     HERO
══════════════════════════════════════════ -->
<section class="hero">
    <div class="hero-glow"></div>
    <div style="position:relative; z-index:1;">
        <div class="hero-badge"><i class="fa-solid fa-dumbbell"></i> Únete a la revolución fitness</div>
        <h1>
            Tu mejor versión<br>
            empieza en <span class="highlight">Style Gym</span>
        </h1>
        <p>
            Entrena con los mejores instructores, accede a clases ilimitadas
            y lleva un control total de tu progreso físico.
        </p>
        <div class="hero-actions">
            <a href="#planes" class="btn-primary">Comenzar ahora</a>
            <a href="#clases"  class="btn-outline">Ver horarios</a>
        </div>

        <div class="hero-stats">
            <div class="hero-stat">
                <h3>+1,200</h3>
                <p>Miembros activos</p>
            </div>
            <div class="hero-stat">
                <h3>18</h3>
                <p>Instructores certificados</p>
            </div>
            <div class="hero-stat">
                <h3>35+</h3>
                <p>Clases semanales</p>
            </div>
            <div class="hero-stat">
                <h3>4.9 <i class="fa-solid fa-star" style="color:#f97316;font-size:0.85em;"></i></h3>
                <p>Calificación promedio</p>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     SERVICIOS
══════════════════════════════════════════ -->
<section class="services" id="servicios">
    <div class="container" style="text-align:center;">
        <span class="section-label">Lo que ofrecemos</span>
        <h2 class="section-title">Todo lo que necesitas para entrenar</h2>
        <p class="section-sub" style="margin: 0 auto;">
            Equipamiento de última generación, clases variadas y un equipo
            que te apoya en cada paso.
        </p>

        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon"><i class="fa-solid fa-dumbbell"></i></div>
                <h3>Área de pesas</h3>
                <p>Zona equipada con máquinas de última generación para entrenamiento de fuerza y musculación.</p>
            </div>
            <div class="service-card">
                <div class="service-icon"><i class="fa-solid fa-person-biking"></i></div>
                <h3>Clases grupales</h3>
                <p>Spinning, Zumba, Yoga, CrossFit y más. Más de 35 clases a la semana con instructores certificados.</p>
            </div>
            <div class="service-card">
                <div class="service-icon"><i class="fa-solid fa-spa"></i></div>
                <h3>Zona de bienestar</h3>
                <p>Área de meditación, yoga y stretching para complementar tu entrenamiento y recuperación.</p>
            </div>
            <div class="service-card">
                <div class="service-icon"><i class="fa-solid fa-chart-line"></i></div>
                <h3>Seguimiento fitness</h3>
                <p>Registra tus medidas, progreso y rutinas desde tu perfil personal en nuestra plataforma.</p>
            </div>
            <div class="service-card">
                <div class="service-icon"><i class="fa-solid fa-blender"></i></div>
                <h3>Área de nutrición</h3>
                <p>Asesoría nutricional y barra de batidos proteicos para apoyar tus metas.</p>
            </div>
            <div class="service-card">
                <div class="service-icon"><i class="fa-solid fa-square-parking"></i></div>
                <h3>Estacionamiento</h3>
                <p>Amplio estacionamiento gratuito para todos nuestros socios. Abierto los 365 días del año.</p>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     HORARIO DE CLASES
══════════════════════════════════════════ -->
