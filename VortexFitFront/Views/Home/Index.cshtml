                        <td><span class="badge-class badge-yoga">Yoga</span></td>
                        <td>Sofía Ramírez</td>
                        <td>15 lugares</td>
                    </tr>
                    <tr>
                        <td>10:00 am</td>
                        <td>—</td>
                        <td><span class="badge-class badge-crossfit">CrossFit</span></td>
                        <td>—</td>
                        <td><span class="badge-class badge-crossfit">CrossFit</span></td>
                        <td>Marco Torres</td>
                        <td>18 lugares</td>
                    </tr>
                    <tr>
                        <td>06:00 pm</td>
                        <td><span class="badge-class badge-zumba">Zumba</span></td>
                        <td><span class="badge-class badge-zumba">Zumba</span></td>
                        <td><span class="badge-class badge-zumba">Zumba</span></td>
                        <td>—</td>
                        <td>Valentina Cruz</td>
                        <td>25 lugares</td>
                    </tr>
                    <tr>
                        <td>08:00 pm</td>
                        <td><span class="badge-class badge-box">Box</span></td>
                        <td>—</td>
                        <td><span class="badge-class badge-box">Box</span></td>
                        <td>—</td>
                        <td>Diego Morales</td>
                        <td>12 lugares</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     PLANES
══════════════════════════════════════════ -->
<section id="planes" style="background: rgba(20,20,20,0.4);">
    <div class="container" style="text-align:center;">
        <span class="section-label">Membresías</span>
        <h2 class="section-title">Elige tu plan</h2>
        <p class="section-sub" style="margin: 0 auto;">
            Sin contratos forzosos. Cancela cuando quieras.
        </p>

        <div class="plans-grid">
            <!-- Plan Básico -->
            <div class="plan-card">
                <p class="plan-name">Básico</p>
                <div class="plan-price">
                    <sup>S/</sup>299<span>/mes</span>
                </div>
                <ul class="plan-features">
                    <li>Acceso al área de pesas</li>
                    <li>Zona cardiovascular</li>
                    <li>2 clases grupales/semana</li>
                    <li>Vestidores y regaderas</li>
                    <li>App de seguimiento</li>
                </ul>
                <a asp-controller="Account" asp-action="Register" asp-route-plan="Basico"
                   class="btn-outline" style="width:100%; text-align:center;">Elegir plan</a>
            </div>

            <!-- Plan Pro (destacado) -->
            <div class="plan-card featured">
                <div class="plan-popular-badge">Más popular</div>
                <p class="plan-name">Pro</p>
                <div class="plan-price">
                    <sup>S/</sup>499<span>/mes</span>
                </div>
                <ul class="plan-features">
                    <li>Todo lo del plan Básico</li>
                    <li>Clases grupales ilimitadas</li>
                    <li>1 sesión con nutriólogo/mes</li>
                    <li>Seguimiento personalizado</li>
                    <li>Acceso a zona wellness</li>
                    <li>Estacionamiento incluido</li>
                </ul>
                <a asp-controller="Account" asp-action="Register" asp-route-plan="Pro"
                   class="btn-primary" style="width:100%; text-align:center;">Elegir plan</a>
            </div>

            <!-- Plan Elite -->
            <div class="plan-card">
                <p class="plan-name">Elite</p>
                <div class="plan-price">
                    <sup>S/</sup>799<span>/mes</span>
                </div>
                <ul class="plan-features">
                    <li>Todo lo del plan Pro</li>
                    <li>Entrenador personal 3x/semana</li>
                    <li>Rutina 100% personalizada</li>
                    <li>Plan nutricional completo</li>
                    <li>Acceso 24/7</li>
                    <li>Taquilla asignada</li>
                </ul>
                <a asp-controller="Account" asp-action="Register" asp-route-plan="Elite"
                   class="btn-outline" style="width:100%; text-align:center;">Elegir plan</a>
            </div>
        </div>
    </div>
</section>

<!-- ══════════════════════════════════════════
     TESTIMONIOS
══════════════════════════════════════════ -->
