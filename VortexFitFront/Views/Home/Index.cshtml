                </p>
                <p class="sede-phone">
                    <i class="fa-solid fa-phone"></i>
                    (01) 345-6789
                </p>
            </div>

            <div class="sede-card">
                <div class="sede-icon"><i class="fa-solid fa-location-dot"></i></div>
                <h3>Sede Surco</h3>
                <p class="sede-address">
                    <i class="fa-solid fa-map-pin"></i>
                    Av. Primavera 890, Santiago de Surco
                </p>
                <p class="sede-hours">
                    <i class="fa-regular fa-clock"></i>
