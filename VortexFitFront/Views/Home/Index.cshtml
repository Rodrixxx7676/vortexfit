<!-- ══════════════════════════════════════════
     CTA FINAL
══════════════════════════════════════════ -->
<section class="cta-section">
    <div class="container">
        <h2>¿Listo para empezar?</h2>
        <p>Únete hoy y obtén tu primer mes con 20% de descuento. Sin compromisos.</p>
        <a href="#planes" class="btn-primary" style="font-size:1.05rem; padding:0.85rem 2.5rem;">
            Registrarme ahora
        </a>
    </div>
</section>
